# =============================================================================
# Configuracion del backend (Vercel / Node)
# =============================================================================
# Copia este archivo a server/.env para desarrollo local:
#   cp server/.env.example server/.env
# En Vercel, estas mismas claves van en Project Settings -> Environment Variables.
# =============================================================================

# Puerto local del server Express (no aplica en Vercel serverless).
PORT=3001

# --- Seguridad ---------------------------------------------------------------
# Clave para firmar los JWT. REQUERIDA en produccion. Minimo 32 chars.
# Genera una con:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# Super admin (login principal). Se valida contra estas dos variables.
# Genera el hash de la password con:
#   node -e "console.log(require('bcryptjs').hashSync('TU_PASSWORD', 10))"
ADMIN_EMAIL=admin@route66.cl
ADMIN_PASSWORD_HASH=

# =============================================================================
# BASE DE DATOS (Postgres)  —  REQUERIDO para las rutas de datos
# =============================================================================
# Connection string de Postgres. El MISMO codigo sirve para Supabase o para
# Vercel Postgres (Neon); solo cambia este valor.
#
# SUPABASE (lo que usas hoy):
#   Dashboard -> Project Settings -> Database -> Connection string -> "URI".
#   Para serverless (Vercel) usa el string del Connection Pooler (puerto 6543,
#   modo Transaction). Ejemplo de forma:
#   postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
#
# VERCEL POSTGRES / NEON (a donde migrar despues, opcional):
#   Vercel -> Storage -> crea una Postgres -> copia POSTGRES_URL / DATABASE_URL.
#
# No commitees el valor real. Aca solo queda el nombre de la variable.
DATABASE_URL=

# Maximo de conexiones por instancia del driver. En serverless deja 1 (el
# pooler de Supabase/Neon ya agrupa del lado servidor).
PG_POOL_MAX=1

# =============================================================================
# STORAGE DE ARCHIVOS (imagenes y modelos .glb)
# =============================================================================
# Elige UNO de los dos backends. Si defines los dos, gana Vercel Blob.

# --- Opcion A: Vercel Blob (storage nativo de Vercel) ------------------------
# Vercel -> Storage -> crea un Blob store -> copia el token de lectura/escritura.
# Esto es lo que usas cuando quieres "todo dentro de Vercel".
BLOB_READ_WRITE_TOKEN=

# --- Opcion B: Supabase Storage (fallback / mientras migras) -----------------
# Permite seguir sirviendo los archivos que ya tienes en Supabase sin migrarlos
# el dia 1. El bucket debe existir y ser publico.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=menu-assets
